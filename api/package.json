{
    "name": "api",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "node src/main.ts",
        "dev": "prisma generate && tsx watch src/main.ts",
        "build": "prisma generate && tsdown --config tsdown.config.ts && tsc-alias",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:studio": "prisma studio",
        "db:push": "prisma db push",
        "db:pull": "prisma db pull"
    },
    "dependencies": {
        "@hono/node-server": "^1.4.1",
        "@hono/zod-validator": "^0.7.6",
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "argon2": "^0.44.0",
        "bcrypt": "latest",
        "dotenv": "^16.3.1",
        "helmet": "latest",
        "hono": "^4.0.0",
        "jsonwebtoken": "latest",
        "nodemailer": "latest",
        "pg": "^8.11.3",
        "pino": "^10.3.1",
        "redis": "^5.11.0",
        "resend": "^6.9.3",
        "zod": "latest"
    },
    "devDependencies": {
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.11.0",
        "@types/nodemailer": "^7.0.11",
        "@types/pg": "^8.11.0",
        "pino-pretty": "^13.1.3",
        "prisma": "^7.4.2",
        "tsdown": "^0.20.3",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    }
}
