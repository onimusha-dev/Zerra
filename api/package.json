{
    "name": "api",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "start": "node src/main.ts",
        "dev": "tsx watch src/main.ts",
        "build": "prisma generate && tsdown --config tsdown.config.ts && tsc-alias",
        "db:generate": "prisma generate",
        "db:studio": "prisma studio",
        "db:push": "prisma db push",
        "db:pull": "prisma db pull",
        "postinstall": "prisma generate",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write"
    },
    "dependencies": {
        "@hono/node-server": "^1.4.1",
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "bcrypt": "latest",
        "dotenv": "^16.3.1",
        "helmet": "latest",
        "hono": "^4.0.0",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "latest",
        "nodemailer": "latest",
        "pg": "^8.11.3",
        "pino": "^10.3.1",
        "zod": "latest"
    },
    "devDependencies": {
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.11.0",
        "@types/pg": "^8.11.0",
        "@types/pino": "^7.0.5",
        "@typescript-eslint/eslint-plugin": "^8.53.1",
        "@typescript-eslint/parser": "^8.53.1",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-unused-imports": "^4.3.0",
        "globals": "^17.4.0",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.1",
        "prisma": "^7.4.2",
        "tsdown": "^0.20.3",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    }
}
