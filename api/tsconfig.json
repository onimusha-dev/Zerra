{
    "extends": "../tsconfig.base.json",

    "compilerOptions": {
        "module": "ESNext",
        "rootDir": "./src",
        "outDir": "./dist",

        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,

        "types": ["node"],

        "baseUrl": "./src",
        "paths": {
            "@platform/*": ["platform/*"],
            "@modules/*": ["modules/*"],
            "@shared/*": ["shared/*"],
            "@/*": ["*"]
        }
    },

    "include": ["src/**/*", "src/generated"],
    "exclude": ["node_modules", "dist"]
}
