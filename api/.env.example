# ──────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=*

# ──────────────────────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://user:password@localhost:5432/myapp

# ──────────────────────────────────────────────────────────────
# Redis cache
# ──────────────────────────────────────────────────────────────

# Use REDIS_URL if using a 3rd party like Render, Upstash, or Aiven
REDIS_URL=rediss://default:password@eu-west-1.rendered.com:6379

# ──────────────────────────────────────────────────────────────
# AI 
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
